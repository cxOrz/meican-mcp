# --- Meican API credentials ---

# OAuth client credentials used by the Meican web API.
MEICAN_CLIENT_ID=change-me
MEICAN_CLIENT_SECRET=change-me

# Optional single-user credentials for local stdio clients. If these are set,
# tools do not need `access_token` and `refresh_token` arguments on every call.
# Values come from www.meican.com cookies: sat -> access, srt -> refresh.
# MEICAN_ACCESS_TOKEN=
# MEICAN_REFRESH_TOKEN=

# Optional fallback namespace. Prefer passing `namespace` per tool call when
# users can belong to different organizations or sites.
# MEICAN_NAMESPACE=

# Optional absolute or relative path to the persistent JSON config. Local
# config values take precedence over environment values. If omitted, the
# platform config directory is used (usually ~/.config/meican-mcp/config.json).
# MEICAN_CONFIG_FILE=

# --- HTTP mode auth ---

# Required only for `meican-mcp http`. Shared bearer key your HTTP MCP client
# sends in the Authorization header.
MCP_API_KEY=change-me-to-a-long-random-string

# --- network ---

# HTTP mode only. Bind address. 127.0.0.1 if you front the server with a
# reverse proxy on the same box; 0.0.0.0 if running in a container with port
# mapping.
BIND_HOST=127.0.0.1
PORT=3000

# --- logging ---

# HTTP mode only: debug | info | warn | error
LOG_LEVEL=info
